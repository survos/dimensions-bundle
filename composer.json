{
    "name": "survos/dimensions-bundle",
    "description": "Physical dimensions value objects and Doctrine integration for Symfony — designed for archival, museum, and document workflows.",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": ["symfony", "dimensions", "museum", "archival", "doctrine", "embeddable", "measurement", "units"],
    "autoload": {
        "psr-4": {
            "Survos\\DimensionsBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Survos\\DimensionsBundle\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.5",
        "symfony/config": "^8.1",
        "symfony/dependency-injection": "^8.1",
        "symfony/http-kernel": "^8.1",
        "doctrine/orm": "^3.0",
        "doctrine/doctrine-bundle": "^3.2",
        "survos/kit-bundle": "^2.5",
        "survos/shape-contracts": "^2.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "symfony/framework-bundle": "^8.1",
        "symfony/twig-bundle": "^8.1",
        "twig/twig": "^3.0",
        "symfony/form": "^8.1",
        "symfony/serializer": "^8.1",
        "api-platform/core": "^4.0"
    },
    "suggest": {
        "symfony/twig-bundle": "To use the |dim, |dim_both, |dim_value Twig filters",
        "symfony/form": "To use DimensionsType form type for W×H×D input",
        "symfony/serializer": "For API Platform and Symfony Serializer integration",
        "api-platform/core": "Automatic API output with display units"
    },
    "extra": {
        "symfony": {
            "require": "^7.0|^8.0"
        }
    }
}
